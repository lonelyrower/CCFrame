# Development Environment Configuration - SQLite Version

# Database - SQLite for development (no setup required)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="dev-secret-key-change-for-production"
NEXTAUTH_URL="http://localhost:3000"
INTERNAL_BASE_URL="http://127.0.0.1:3000"

# Bootstrap admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# Storage - Using local storage for development
STORAGE_PROVIDER="local"
UPLOAD_PATH="./uploads"
LOCAL_STORAGE_PATH="./uploads"

# Development settings
NODE_ENV="development"
DEV_MODE="true"

# Optional Redis (not required for basic functionality)
# REDIS_URL="redis://localhost:6379"

# Optional S3/MinIO (not required for local development)
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET_NAME=""
# S3_REGION=""
# S3_ENDPOINT=""

# 其他配置
FORCE_HTTPS="false"
# CDN_BASE_URL=""