# Production Environment Configuration for VPS

# Database - PostgreSQL
DATABASE_URL="postgresql://ccframe_user:your_secure_password@localhost:5432/ccframe_db"

# NextAuth
NEXTAUTH_SECRET="your-very-secure-nextauth-secret-key-for-production"
NEXTAUTH_URL="https://your-domain.com"
INTERNAL_BASE_URL="http://127.0.0.1:3000"

# Bootstrap admin
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your-secure-admin-password"

# Storage - 推荐使用MinIO或AWS S3用于生产环境
STORAGE_PROVIDER="minio"  # 或 "aws", "aliyun", "qcloud"

# MinIO配置 (推荐用于VPS)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-minio-access-key"
S3_SECRET_ACCESS_KEY="your-minio-secret-key"
S3_BUCKET="ccframe-photos"
S3_FORCE_PATH_STYLE="true"

# Redis (强烈推荐用于生产环境)
REDIS_URL="redis://localhost:6379"

# 图片处理配置
NEXT_PUBLIC_IMAGE_SERVE_MODE="redirect"  # 生产环境推荐使用redirect模式
IMAGE_PUBLIC_VARIANTS="true"
IMAGE_FORMATS="webp,avif,jpeg"
IMAGE_VARIANT_NAMES="thumb,small,medium,large"
UPLOAD_CONCURRENCY="8"
IMG_WORKER_CONCURRENCY="6"

# API配置
PIXABAY_API_KEY="your-pixabay-api-key"
SEED_TOKEN=""  # 生产环境建议禁用seed功能
SEED_MAX_COUNT="0"

# 功能开关
NEXT_PUBLIC_ENABLE_PWA="true"

# 语义搜索配置
ENABLE_SEMANTIC_SEARCH="true"
SEMANTIC_USE_PGVECTOR="on"  # PostgreSQL环境推荐开启
EMBED_PROVIDER="openai"     # 或 "deterministic"
EMBED_MODEL_NAME="text-embedding-3-small"
OPENAI_API_KEY="your-openai-api-key"

# 安全配置
ALLOWED_ORIGINS="https://your-domain.com"
RATE_LIMIT_ENABLED="true"

# 监控配置 (可选)
ENABLE_METRICS="true"
SENTRY_DSN="your-sentry-dsn"