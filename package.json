    "db:status": "prisma migrate status",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "db:studio": "prisma studio",
    "variants:backfill": "tsx scripts/backfill-variants.ts",
    "analyze": "ANALYZE=true next build"
  },
