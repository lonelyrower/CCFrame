// This is your Prisma schema file for SQLite development
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String   @map("password_hash")
  twoFASecret      String?  @map("twofa_secret")
  pixabayApiKey    String?  @map("pixabay_api_key")
  defaultSeedCount Int?     @default(12) @map("default_seed_count")
  createdAt        DateTime @default(now()) @map("created_at")
  
  albums  Album[]
  photos  Photo[]
  jobs    Job[]
  audits  Audit[]
  photoNotes PhotoNote[]
  smartAlbums SmartAlbum[]
  
  @@map("users")
}

model Album {
  id           String  @id @default(cuid())
  title        String
  description  String?
  coverPhotoId String? @map("cover_photo_id")
  visibility   String  @default("PUBLIC") // "PUBLIC" or "PRIVATE"
  sortOrder    Int     @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  photos     Photo[]
  coverPhoto Photo? @relation("AlbumCover", fields: [coverPhotoId], references: [id])
  
  @@map("albums")
}

model SmartAlbum {
  id          String   @id @default(cuid())
  title       String
  description String?
  query       String   // JSON string containing query parameters
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("smart_albums")
}

model Photo {
  id                   String   @id @default(cuid())
  url                  String?  
  localPath            String?  @map("local_path")
  originalFileName     String?  @map("original_file_name")
  aspectRatio          Float?   @map("aspect_ratio")
  width                Int?
  height               Int?
  blurHashDataURL      String?  @map("blur_hash_data_url")
  status               String   @default("PENDING") // "PENDING", "COMPLETED", "FAILED", "ARCHIVED"
  visibility           String   @default("PUBLIC") // "PUBLIC" or "PRIVATE"
  extractedCoordinates String?  @map("extracted_coordinates") // JSON string
  dominantColor        String?  @map("dominant_color") // hex color
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumId String? @map("album_id")
  album   Album?  @relation(fields: [albumId], references: [id])
  
  photoTags      PhotoTag[]
  notes          PhotoNote[]
  favoritedBy    UserPhotoFavorite[]
  variants       PhotoVariant[]
  albumCovers    Album[] @relation("AlbumCover")
  
  @@map("photos")
}

model PhotoVariant {
  id        String @id @default(cuid())
  photoId   String @map("photo_id")
  size      String // "thumbnail", "small", "medium", "large"
  format    String // "webp", "jpeg", "png"
  url       String?
  localPath String? @map("local_path")
  width     Int?
  height    Int?
  fileSize  Int?    @map("file_size")
  
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@unique([photoId, size, format])
  @@map("photo_variants")
}

model PhotoNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  photoId String @map("photo_id")
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("photo_notes")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1") // hex color
  createdAt DateTime @default(now()) @map("created_at")
  
  photoTags PhotoTag[]
  
  @@map("tags")
}

model PhotoTag {
  photoId String @map("photo_id")
  tagId   String @map("tag_id")
  
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([photoId, tagId])
  @@map("photo_tags")
}

model UserPhotoFavorite {
  userId  String @map("user_id")
  photoId String @map("photo_id")
  
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@id([userId, photoId])
  @@map("user_photo_favorites")
}

model Job {
  id        String   @id @default(cuid())
  type      String   // JOB_TYPE enum as string
  status    String   @default("PENDING") // JOB_STATUS enum as string
  data      String?  // JSON string
  result    String?  // JSON string
  error     String?  // JSON string
  progress  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("jobs")
}

model Audit {
  id        String   @id @default(cuid())
  action    String   // ACTION_TYPE enum as string
  entityId  String   @map("entity_id")
  entityType String  @map("entity_type")
  details   String?  // JSON string
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("audits")
}

model Config {
  key   String @id
  value String
  
  @@map("config")
}

model SystemInfo {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@map("system_info")
}