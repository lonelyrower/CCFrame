// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String   @map("password_hash")
  twoFASecret      String?  @map("twofa_secret")
  pixabayApiKey    String?  @map("pixabay_api_key")
  defaultSeedCount Int?     @default(12) @map("default_seed_count")
  createdAt        DateTime @default(now()) @map("created_at")
  
  albums  Album[]
  photos  Photo[]
  jobs    Job[]
  audits  Audit[]
  smartAlbums SmartAlbum[]
  
  @@map("users")
}

model Album {
  id           String  @id @default(cuid())
  title        String
  description  String?
  coverPhotoId String? @map("cover_photo_id")
  visibility   String  @default("PUBLIC") // "PUBLIC" or "PRIVATE"
  sortOrder    Int     @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  photos     Photo[]
  coverPhoto Photo? @relation("AlbumCover", fields: [coverPhotoId], references: [id])
  
  @@map("albums")
}

model Photo {
  id         String   @id @default(cuid())
  fileKey    String   @map("file_key")
  hash       String
  contentHash String? @map("content_hash")
  width      Int
  height     Int
  takenAt    DateTime? @map("taken_at")
  location   Json?    @map("location")
  exifJson   Json?    @map("exif_json")
  visibility String   @default("PUBLIC") // "PUBLIC" or "PRIVATE"
  status     String   @default("UPLOADING") // "UPLOADING", "PROCESSING", "COMPLETED", "FAILED"
  blurhash   String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  
  userId  String  @map("user_id")
  albumId String? @map("album_id")
  
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)
  
  variants     PhotoVariant[]
  tags         PhotoTag[]
  faces        Face[]
  albumCovers  Album[]        @relation("AlbumCover")
  smartAlbumCovers SmartAlbum[] @relation("SmartAlbumCover")
  editVersions EditVersion[]
  embedding  PhotoEmbedding?
  
  @@index([userId])
  @@index([albumId])
  @@index([visibility])
  @@index([takenAt])
  @@index([status])
  @@index([hash])
  @@index([contentHash])
  @@map("photos")
}

model PhotoVariant {
  id        String @id @default(cuid())
  variant   String // "thumb", "small", "medium", "large", "original"
  format    String // "avif", "webp", "jpeg"
  width     Int
  height    Int
  fileKey   String @map("file_key")
  sizeBytes Int    @map("size_bytes")
  
  photoId String @map("photo_id")
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@unique([photoId, variant, format])
  @@map("photo_variants")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7280") // hex color
  
  photos PhotoTag[]
  
  @@map("tags")
}

model PhotoTag {
  photoId String @map("photo_id")
  tagId   String @map("tag_id")
  
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([photoId, tagId])
  @@map("photo_tags")
}

model Face {
  id        String  @id @default(cuid())
  bbox      String  // JSON string: {x, y, width, height}
  personId  String? @map("person_id")
  embedding Bytes? // face embedding for similarity
  
  photoId String @map("photo_id")
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@map("faces")
}

model Job {
  id          String   @id @default(cuid())
  type        String   // "THUMBNAIL_GENERATION", "EXIF_EXTRACTION", "AI_ENHANCEMENT", etc.
  payloadJson Json     @map("payload_json")
  status      String   @default("PENDING") // "PENDING", "RUNNING", "COMPLETED", "FAILED"
  progress    Int      @default(0) // 0-100
  resultJson  Json?    @map("result_json")
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("jobs")
}

model EditVersion {
  id        String   @id @default(cuid())
  name      String   // "Original", "Enhanced", "Upscaled", etc.
  fileKey   String   @map("file_key")
  params    String?  @map("params") // JSON string: edit parameters for reproducibility
  createdAt DateTime @default(now()) @map("created_at")
  
  photoId String @map("photo_id")
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@map("edit_versions")
}

model Audit {
  id         String   @id @default(cuid())
  action     String   // "LOGIN", "UPLOAD", "DELETE", "EDIT", "EXPORT", "SHARE"
  targetType String   @map("target_type") // "photo", "album", etc.
  targetId   String   @map("target_id")
  meta       Json?    @map("meta")
  createdAt  DateTime @default(now()) @map("created_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("audits")
}

model SmartAlbum {
  id          String   @id @default(cuid())
  title       String
  description String?
  ruleJson    Json     @map("rule_json")
  visibility  String   @default("PRIVATE")
  coverPhotoId String? @map("cover_photo_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coverPhoto Photo? @relation("SmartAlbumCover", fields: [coverPhotoId], references: [id])

  @@map("smart_albums")
}

// Application-level settings (singleton row)
model AppSettings {
  id             String   @id @default("singleton")
  openaiApiKey   String?  @map("openai_api_key")
  googleApiKey   String?  @map("google_api_key")
  clipdropApiKey String?  @map("clipdrop_api_key")
  removeBgApiKey String?  @map("remove_bg_api_key")
  // Storage strategy
  imageFormats      String? @map("image_formats")
  imageVariantNames String? @map("image_variant_names")
  // Auto-tagging preferences
  autoTagEnabled         Boolean  @default(false) @map("auto_tag_enabled")
  autoTagIncludeColors   Boolean  @default(true)  @map("auto_tag_include_colors")
  autoTagIncludeContent  Boolean  @default(true)  @map("auto_tag_include_content")
  autoTagProvider        String?               @map("auto_tag_provider") // 'auto' | 'gemini' | 'openai'
  autoTagDailyLimit      Int?                  @map("auto_tag_daily_limit")
  autoTagUsageDate       String?               @map("auto_tag_usage_date") // YYYY-MM-DD
  autoTagUsageCount      Int       @default(0) @map("auto_tag_usage_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
model PhotoEmbedding {
  photoId   String  @id @map("photo_id")
  embedding Bytes   @map("embedding")
  model     String  @default("deterministic")
  provider  String  @default("deterministic")
  dim       Int     @default(768)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@map("photo_embeddings")
}
