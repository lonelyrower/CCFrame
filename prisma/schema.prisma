// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  twoFASecret  String?  @map("twofa_secret")
  createdAt    DateTime @default(now()) @map("created_at")
  
  albums  Album[]
  photos  Photo[]
  jobs    Job[]
  audits  Audit[]
  
  @@map("users")
}

enum Visibility {
  PUBLIC
  PRIVATE
}

model Album {
  id           String     @id @default(cuid())
  title        String
  description  String?
  coverPhotoId String?    @map("cover_photo_id")
  visibility   Visibility @default(PUBLIC)
  sortOrder    Int        @default(0) @map("sort_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  photos     Photo[]
  coverPhoto Photo? @relation("AlbumCover", fields: [coverPhotoId], references: [id])
  
  @@map("albums")
}

enum PhotoStatus {
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
}

model Photo {
  id         String      @id @default(cuid())
  fileKey    String      @map("file_key")
  hash       String      @unique
  width      Int
  height     Int
  takenAt    DateTime?   @map("taken_at")
  location   Json?       // {lat, lng, address}
  exifJson   Json?       @map("exif_json")
  visibility Visibility  @default(PUBLIC)
  status     PhotoStatus @default(UPLOADING)
  blurhash   String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  
  userId  String  @map("user_id")
  albumId String? @map("album_id")
  
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)
  
  variants     PhotoVariant[]
  tags         PhotoTag[]
  faces        Face[]
  albumCovers  Album[]        @relation("AlbumCover")
  editVersions EditVersion[]
  
  @@index([userId])
  @@index([albumId])
  @@index([visibility])
  @@index([takenAt])
  @@index([status])
  @@map("photos")
}

model PhotoVariant {
  id        String @id @default(cuid())
  variant   String // "thumb", "small", "medium", "large", "original"
  format    String // "avif", "webp", "jpeg"
  width     Int
  height    Int
  fileKey   String @map("file_key")
  sizeBytes Int    @map("size_bytes")
  
  photoId String @map("photo_id")
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@unique([photoId, variant, format])
  @@map("photo_variants")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7280") // hex color
  
  photos PhotoTag[]
  
  @@map("tags")
}

model PhotoTag {
  photoId String @map("photo_id")
  tagId   String @map("tag_id")
  
  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@id([photoId, tagId])
  @@map("photo_tags")
}

model Face {
  id        String  @id @default(cuid())
  bbox      Json    // {x, y, width, height}
  personId  String? @map("person_id")
  embedding Bytes? // face embedding for similarity
  
  photoId String @map("photo_id")
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@map("faces")
}

enum JobType {
  THUMBNAIL_GENERATION
  EXIF_EXTRACTION
  AI_ENHANCEMENT
  AI_UPSCALE
  AI_REMOVE_BACKGROUND
  AI_STYLE_TRANSFER
  FACE_DETECTION
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Job {
  id          String    @id @default(cuid())
  type        JobType
  payloadJson Json      @map("payload_json")
  status      JobStatus @default(PENDING)
  progress    Int       @default(0) // 0-100
  resultJson  Json?     @map("result_json")
  errorMsg    String?   @map("error_msg")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("jobs")
}

model EditVersion {
  id        String   @id @default(cuid())
  name      String   // "Original", "Enhanced", "Upscaled", etc.
  fileKey   String   @map("file_key")
  params    Json? // edit parameters for reproducibility
  createdAt DateTime @default(now()) @map("created_at")
  
  photoId String @map("photo_id")
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  
  @@map("edit_versions")
}

enum AuditAction {
  LOGIN
  UPLOAD
  DELETE
  EDIT
  EXPORT
  SHARE
}

model Audit {
  id         String      @id @default(cuid())
  action     AuditAction
  targetType String      @map("target_type") // "photo", "album", etc.
  targetId   String      @map("target_id")
  meta       Json? // additional context
  createdAt  DateTime    @default(now()) @map("created_at")
  
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audits")
}