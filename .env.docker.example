# ---------- Core ----------
NEXTAUTH_URL=http://localhost
NEXTAUTH_SECRET=replace-with-long-random-string

# Admin account (auto-created on first start)
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=admin123

# ---------- Database (internal) ----------
POSTGRES_USER=ccframe
POSTGRES_PASSWORD=ccframe
POSTGRES_DB=ccframe

# Application DATABASE_URL pointing to postgres container
DATABASE_URL=postgresql://ccframe:ccframe@db:5432/ccframe

# ---------- Redis (internal) ----------
REDIS_URL=redis://redis:6379

# ---------- S3 / MinIO ----------
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=ccframe
S3_REGION=us-east-1
# For in-cluster access the app uses http://minio:9000
# Optional: public CDN base if you front the bucket
CDN_BASE_URL=

# ---------- Optional AI ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---------- MinIO Console (mapped to 9001) ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

