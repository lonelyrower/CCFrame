# CCFrame 生产环境配置模板
# 复制此文件为 .env.production 并填入实际值

# 数据库配置
DATABASE_URL="postgresql://gallery_user:YOUR_PASSWORD@localhost:5432/photo_gallery"

# NextAuth 认证配置
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET_32_CHARS_OR_MORE"
NEXTAUTH_URL="https://your-domain.com"

# Redis 缓存配置 (可选但推荐)
REDIS_URL="redis://localhost:6379"

# 存储配置
STORAGE_PROVIDER="local"
# 本地存储路径
UPLOAD_PATH="/var/www/ccframe/uploads"

# S3 存储配置 (如果使用云存储)
# STORAGE_PROVIDER="s3"
# S3_BUCKET="your-bucket-name"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"
# S3_ENDPOINT="https://s3.amazonaws.com"

# 管理员账户
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="YOUR_SECURE_ADMIN_PASSWORD"

# 应用配置
NODE_ENV="production"
PORT="3000"

# 性能优化
NEXT_TELEMETRY_DISABLED=1

# 图片处理配置
MAX_IMAGE_SIZE="10485760"
MAX_CONCURRENT_UPLOADS="3"
SUPPORTED_IMAGE_TYPES="jpg,jpeg,png,webp,heic"

# 缓存配置
CACHE_TTL="3600"
IMAGE_CACHE_TTL="31536000"

# 日志配置
LOG_LEVEL="info"

# API 限流配置
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900000"

# 语义搜索配置 (可选) - AI图片处理功能已移除，仅保留语义搜索
# SEMANTIC_SEARCH_ENABLED="false"
# OPENAI_API_KEY="your-openai-key"
# EMBEDDING_MODEL="text-embedding-3-small"

# 安全配置
SECURE_COOKIES="true"