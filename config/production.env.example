# CCFrame production environment template
# Copy this file to config/production.env and adjust values before deploying.

# Core application settings
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=replace-with-strong-random-string

# Database
DATABASE_URL=postgresql://ccframe:supersecure@db:5432/ccframe?schema=public

# Redis (recommended for queues & caching)
REDIS_URL=redis://redis:6379

# Initial admin bootstrap
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-me-after-deploy

# File storage (S3-compatible example)
STORAGE_PROVIDER=s3
S3_BUCKET_NAME=ccframe-assets
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
CDN_BASE_URL=https://cdn.your-domain.com

# Optional: switch to local storage for single-node deployments
# STORAGE_PROVIDER=local
# UPLOAD_PATH=/var/www/ccframe/uploads

# Feature toggles
RATE_LIMIT_ENABLED=true
CACHE_TTL=3600
IMAGE_CACHE_TTL=31536000

# Semantic / AI features (leave commented if unused)
# OPENAI_API_KEY=sk-...
# SEMANTIC_SEARCH_ENABLED=false
# EMBEDDING_MODEL=text-embedding-3-small
