# 确保 shell 脚本使用 LF 行尾符（适用于 Linux/macOS）
*.sh text eol=lf

# 确保批处理脚本使用 CRLF 行尾符（适用于 Windows）
*.bat text eol=crlf
*.cmd text eol=crlf

# 其他文本文件使用 Git 默认处理
*.md text
*.json text
*.yaml text
*.yml text
*.toml text
*.ts text
*.tsx text
*.js text
*.jsx text
*.css text
*.scss text
*.html text

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
