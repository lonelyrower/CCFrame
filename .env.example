# Database
DATABASE_URL="postgresql://username:password@localhost:5432/photo_gallery"

# NextAuth
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# S3 Compatible Storage
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="your-bucket-name"
S3_REGION="us-east-1"
S3_ENDPOINT="https://s3.amazonaws.com" # or your minio endpoint

# Redis
REDIS_URL="redis://localhost:6379"

# CDN
CDN_BASE_URL="https://your-cdn-domain.com"

# Image serving mode (stream/redirect)
# - development: keep 'stream' to hide internal storage endpoints
# - production (recommended): set to 'redirect' to offload bandwidth to storage/CDN
NEXT_PUBLIC_IMAGE_SERVE_MODE="redirect"

# Public variants (production optional)
# If true, /api/image/serve will redirect to public URLs (CDN/S3) for VARIANTS ONLY.
# Private photos still use signed URLs. Ensure your bucket policy allows public read
# for the 'variants/' prefix ONLY; do NOT expose originals.
IMAGE_PUBLIC_VARIANTS="true"

# Optional: control which variants and formats are generated to manage cost/perf
IMAGE_FORMATS="webp,jpeg"
IMAGE_VARIANT_NAMES="thumb,small,medium"

# App Settings
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="secure-password"

# StorageManager Provider (minio/aws/aliyun/qcloud)
STORAGE_PROVIDER="minio"

# Aliyun OSS (可选)
ALIYUN_REGION="cn-hangzhou"
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_SECRET_ACCESS_KEY=""
ALIYUN_OSS_BUCKET=""
ALIYUN_CDN_URL=""

# Tencent COS (可选)
QCLOUD_REGION="ap-shanghai"
QCLOUD_SECRET_ID=""
QCLOUD_SECRET_KEY=""
QCLOUD_COS_BUCKET=""
QCLOUD_CDN_URL=""
# AI图片处理APIs已移除 - 用户不需要此功能

# Dev seed (测试数据)
PIXABAY_API_KEY=""
DEV_SEED_TOKEN=""
# 内部回源地址（服务端自访本机图片接口时使用）
# 默认为 http://127.0.0.1:3000；如你的服务监听在其它端口或域名，请修改
# INTERNAL_BASE_URL="http://127.0.0.1:3000"
# 最大导入数量（每次点击“导入示例图片”的上限）；默认5，可根据网络与CPU调整
SEED_MAX_COUNT="5"
# 硬上限（防止误配过大），默认50
# SEED_HARD_MAX="50"
