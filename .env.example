# --- Database --------------------------------------------------------------
# Generate dedicated credentials for local usage, do NOT reuse production ones.
# Example: create role via `createuser --pwprompt ccframe_dev` and update the URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/photo_gallery"

# --- NextAuth --------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"
INTERNAL_BASE_URL="http://127.0.0.1:3000"

# --- Bootstrap admin (local only, rotate immediately in real envs) ---------
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-on-first-login"

# --- Storage configuration -------------------------------------------------
# Choose provider: local | minio | aws | aliyun | qcloud
STORAGE_PROVIDER="local"
S3_ACCESS_KEY_ID="local-access-key"
S3_SECRET_ACCESS_KEY="local-secret-key"
S3_BUCKET_NAME="photo-gallery"
S3_REGION="us-east-1"
S3_ENDPOINT="http://127.0.0.1:9000"
CDN_BASE_URL=""

# --- Redis (optional, required for rate limiting/queues) -------------------
REDIS_URL="redis://localhost:6379"

# --- Image processing options ---------------------------------------------
NEXT_PUBLIC_IMAGE_SERVE_MODE="stream"
IMAGE_PUBLIC_VARIANTS="false"
IMAGE_FORMATS="webp,jpeg"
IMAGE_VARIANT_NAMES="thumb,small,medium"
UPLOAD_CONCURRENCY="4"
IMG_WORKER_CONCURRENCY="3"

# --- Seeding / Third-party APIs -------------------------------------------
PIXABAY_API_KEY=""
DEV_SEED_TOKEN=""
SEED_MAX_COUNT="5"

# --- Optional providers ----------------------------------------------------
ALIYUN_REGION=""
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_SECRET_ACCESS_KEY=""
ALIYUN_OSS_BUCKET=""
ALIYUN_CDN_URL=""

QCLOUD_REGION=""
QCLOUD_SECRET_ID=""
QCLOUD_SECRET_KEY=""
QCLOUD_COS_BUCKET=""
QCLOUD_CDN_URL=""

# --- Feature toggles -------------------------------------------------------
NEXT_PUBLIC_ENABLE_PWA="false"
# --- Semantic Search -----------------------------------------------------
ENABLE_SEMANTIC_SEARCH="true"
SEMANTIC_USE_PGVECTOR="off"
EMBED_PROVIDER="openai"
EMBED_MODEL_NAME="text-embedding-3-small"
EMBED_DIM="1536"
# Add your OpenAI API key below for enhanced semantic search
# OPENAI_API_KEY="sk-your-api-key-here"

