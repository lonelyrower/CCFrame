# Database
DATABASE_URL="postgresql://username:password@localhost:5432/photo_gallery"

# NextAuth
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# S3 Compatible Storage
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="your-bucket-name"
S3_REGION="us-east-1"
S3_ENDPOINT="https://s3.amazonaws.com" # or your minio endpoint

# Redis
REDIS_URL="redis://localhost:6379"

# AI APIs (Optional)
OPENAI_API_KEY="your-openai-key"
ANTHROPIC_API_KEY="your-anthropic-key"
# 支持 GOOGLE_AI_API_KEY 或 GOOGLE_API_KEY
GOOGLE_AI_API_KEY="your-google-key"
GOOGLE_API_KEY="your-google-key"

# CDN
CDN_BASE_URL="https://your-cdn-domain.com"

# App Settings
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="secure-password"

# StorageManager Provider (minio/aws/aliyun/qcloud)
STORAGE_PROVIDER="minio"

# Aliyun OSS (可选)
ALIYUN_REGION="cn-hangzhou"
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_SECRET_ACCESS_KEY=""
ALIYUN_OSS_BUCKET=""
ALIYUN_CDN_URL=""

# Tencent COS (可选)
QCLOUD_REGION="ap-shanghai"
QCLOUD_SECRET_ID=""
QCLOUD_SECRET_KEY=""
QCLOUD_COS_BUCKET=""
QCLOUD_CDN_URL=""
# AI APIs (Optional)

# Dev seed (测试数据)
PIXABAY_API_KEY=""
DEV_SEED_TOKEN=""
